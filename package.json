{
  "name": "stewart-platform-server",
  "private": true,
  "scripts": {
    "start": "node server.js",
    "build": "~/.platformio/penv/bin/pio run",
    "upload": "curl -s localhost:3000/api/release && sleep 1 && ~/.platformio/penv/bin/pio run -t upload",
    "upload:ota": "node sysid/ota_upload.js",
    "can:budget": "node sysid/can_budget.js",
    "can:benchmark": "node sysid/can_benchmark.js",
    "can:bitrate-frames": "node sysid/can_bitrate_frames.js --speed 1m",
    "health": "node sysid/health_check.js",
    "net:health": "node sysid/net_health.js",
    "safe:baseline": "node sysid/safe_baseline.js",
    "safe:land": "node sysid/safe_land.js",
    "research:trial": "node sysid/research_trial.js",
    "workspace:session": "node sysid/workspace_session.js",
    "workspace:optimize": "node sysid/workspace_optimize.js",
    "workspace:validate": "node sysid/validate_motion_library.js",
    "program:leaderboard": "node sysid/program_leaderboard.js",
    "workspace:deep-report": "node sysid/workspace_deep_report.js",
    "workspace:waveforms": "node sysid/workspace_waveform_report.js",
    "z:sweep": "node sysid/z_sweep_trial.js",
    "coupling:probe": "node sysid/coupling_probe.js",
    "coupling:summary": "node sysid/coupling_summary.js",
    "heave:metrics": "node sysid/heave_step_metrics.js",
    "stability:score": "node sysid/stability_score.js",
    "motion:plot6": "node sysid/plot_motion6.js",
    "experiment:manifest": "node sysid/experiment_manifest.js",
    "research:index": "node sysid/research_index.js",
    "telemetry:summary": "node sysid/telemetry_summary.js",
    "motion:profile": "node sysid/motion_profile.js --to 0,0,115,0,0,0"
  },
  "dependencies": {
    "serialport": "^12.0.0",
    "ws": "^8.18.0"
  }
}
